{
  "editor.formatOnSave": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "[python]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "ruff.configuration": "./pyproject.toml"
  },
	"files.exclude": {
		"**/.venv": true,
		"**/__pycache__": true
	},
	"search.exclude": {
		"**/.venv": true,
		"**/__pycache__": true
	}	
}
